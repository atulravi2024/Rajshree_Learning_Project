    numbers_100: (() => {
        const hindiNumbersNames = ["शून्य", "एक", "दो", "तीन", "चार", "पाँच", "छह", "सात", "आठ", "नौ", "दस", "ग्यारह", "बारह", "तेरह", "चौदह", "पंद्रह", "सोलह", "सत्रह", "अठारह", "उन्नीस", "बीस", "इक्कीस", "बाईस", "तेईस", "चौबीस", "पच्चीस", "छब्बीस", "सत्ताईस", "अट्ठाइस", "उनतीस", "तीस", "इकतीस", "बत्तीस", "तैंतीस", "चौंतीस", "पैंतीस", "छत्तीस", "सैंतीस", "अड़तीस", "उनतालीस", "चालीस", "इकतालीस", "बयालीस", "तैंतालीस", "चवालीस", "पैंतालीस", "छियालीस", "सैंतालीस", "अड़तालीस", "उनचाas", "पचाas", "इक्यावन", "बावन", "तिरपन", "चौवन", "पचपन", "छप्पन", "सत्तावन", "अठावन", "उनसठ", "साठ", "इकसठ", "बासठ", "तिरसठ", "चौंसठ", "पैंसठ", "छियासठ", "सरसठ", "अड़सठ", "उनहत्तर", "सत्तर", "इकहत्तर", "बहत्तर", "तिहत्तर", "चौहत्तर", "पचहत्तर", "छिहत्तर", "सतहत्तर", "अठहत्तर", "उनासी", "अस्सी", "इक्यासी", "बयासी", "तिरासी", "चौरासी", "पचासी", "छियासी", "सतासी", "अठासी", "नवासी", "नब्बे", "इक्यानवे", "बयानवे", "तिरानवे", "चौरानवे", "पंचानवे", "छियाanve", "सत्तानवे", "अट्ठानवे", "निन्यानवे", "सौ"];
        const hindiNumeralsDigits = ["०", "१", "२", "३", "४", "५", "६", "७", "८", "९"];
        const toHindi = (num) => num.toString().split('').map(d => hindiNumeralsDigits[parseInt(d)]).join('');
        const unitIcons = ["🥚", "🍎", "🍐", "🍊", "🍋", "🍌", "🍉", "🍇", "🍓", "🍍"];
        
        return Array.from({length: 100}, (_, i) => {
            const n = i + 1;
            const s = n.toString();
            let iconStr = "";
            
            if (n === 100) {
                iconStr = "💯";
            } else if (n < 10) {
                iconStr = unitIcons[n].repeat(n);
            } else {
                const firstDigit = parseInt(s[0]);
                const secondDigit = parseInt(s[1]);
                iconStr = unitIcons[firstDigit];
                if (secondDigit === 0) {
                    iconStr += "🥚";
                } else {
                    iconStr += unitIcons[secondDigit];
                }
            }
            
            return {
                letter: toHindi(n),
                word: hindiNumbersNames[n],
                emoji: iconStr,
                audio: `assets/audio/ganit/numbers/num_${n}.mp3`,
                value: n.toString()
            };
        });
    })(),
    tables_10_m1: (() => {
        const tables = [];
        const unitIcons = ["🥚", "🍎", "🍐", "🍊", "🍋", "🍌", "🍉", "🍇", "🍓", "🍍", "🍎🥚"];
        for (let n = 2; n <= 10; n++) {
            let leftCol = "";
            let rightCol = "";
            for (let i = 1; i <= 10; i++) {
                const line = `${n} x ${i} = ${n * i}<br>`;
                if (i <= 5) leftCol += line;
                else rightCol += line;
            }
            const hindiNumerals = ["०", "१", "२", "३", "४", "५", "६", "७", "८", "९", "१०"];
            const toHindi = (num) => num.toString().split('').map(d => hindiNumerals[parseInt(d)]).join('');

            tables.push({ 
                letter: toHindi(n), 
                word: `पहाड़ा`, 
                emoji: unitIcons[n], 
                audio: `assets/audio/ganit/tables/method_1/table_${n}_m1.mp3`, 
                content: `<div style="text-align:center;"><b style="font-size:4.5vh; color:#FF5722;">स्कूल पद्धति</b></div>
                          <div style="display:flex; justify-content:center; align-items: flex-start; font-size:4.5vh; margin-top:15px; font-weight:bold; gap: 30px;">
                            <div style="text-align:left;">${leftCol}</div>
                            <div style="width: 3px; background: #FFDEE9; height: 35vh; align-self: center;"></div>
                            <div style="text-align:left;">${rightCol}</div>
                          </div>`
            });
        }
        return tables;
    })(),
    tables_10_m2: (() => {
        const tables = [];
        const unitIcons = ["🥚", "🍎", "🍐", "🍊", "🍋", "🍌", "🍉", "🍇", "🍓", "🍍", "🍎🥚"];
        for (let n = 2; n <= 10; n++) {
            let leftCol = "";
