            const hNums = ["०", "एक", "दो", "तीन", "चार", "पाँच", "छह", "सात", "आठ", "नौ", "दस"];
            for (let i = 1; i <= 10; i++) {
                const line = `${n} ${hNums[i]} जा ${n * i}<br>`;
                if (i <= 5) leftCol += line;
