                content: `<div style="text-align:center;"><b style="font-size:4.5vh; color:#2196F3;">बोलचाल पद्धति</b></div>
                          <div style="display:flex; justify-content:center; align-items: flex-start; font-size:4vh; margin-top:15px; font-weight:bold; gap: 30px;">
                            <div style="text-align:left;">${leftCol}</div>
